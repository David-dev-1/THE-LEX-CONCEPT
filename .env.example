# ---- Database (required) ----
# One single Postgres connection string, used identically for local
# development and production. This keeps the two environments identical,
# so nothing that works on your machine can mysteriously fail once
# deployed to Vercel.
#
# Get a free database in about 2 minutes at https://neon.tech (no credit
# card needed). On your Neon project dashboard, click "Connect", and use
# the connection string shown there. If there's a "Connection pooling"
# toggle, turn it OFF and copy that string - this app uses a single direct
# connection rather than juggling separate pooled/unpooled URLs, since a
# small single-admin site like this never comes close to needing pooling,
# and keeping this as one variable avoids a whole class of setup mistakes.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth ----
# Generate a strong random secret, e.g. run: openssl rand -base64 32
JWT_SECRET="replace-this-with-a-long-random-string-before-going-live"

# ---- Initial admin account (used by prisma/seed.js) ----
ADMIN_EMAIL="admin@thelexconcept.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Alexandra Fajemirokun"

# ---- Image storage (optional, production) ----
# If left blank, uploaded images are saved to /public/uploads (fine for local
# dev, but Vercel's serverless filesystem is ephemeral, so uploads will NOT
# persist there long-term).
# Create a free Vercel Blob store (Vercel dashboard -> Storage -> Marketplace
# -> Blob) and paste the token below to make uploads production-ready.
BLOB_READ_WRITE_TOKEN=""
